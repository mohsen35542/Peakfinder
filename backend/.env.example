# ================ اپلیکیشن ================
APP_NAME=PeakFinder Quantum
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production

# ================ دیتابیس ================
DATABASE_URL=postgresql://postgres:password@localhost:5432/peakfinder

# ================ Redis ================
REDIS_URL=redis://localhost:6379/0

# ================ صرافی‌ها (۱۰ صرافی) ================
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key

BYBIT_API_KEY=your-bybit-api-key
BYBIT_SECRET_KEY=your-bybit-secret-key

KUCOIN_API_KEY=your-kucoin-api-key
KUCOIN_SECRET_KEY=your-kucoin-secret-key
KUCOIN_PASSPHRASE=your-kucoin-passphrase

GATEIO_API_KEY=your-gateio-api-key
GATEIO_SECRET_KEY=your-gateio-secret-key

MEXC_API_KEY=your-mexc-api-key
MEXC_SECRET_KEY=your-mexc-secret-key

HUOBI_API_KEY=your-huobi-api-key
HUOBI_SECRET_KEY=your-huobi-secret-key

OKX_API_KEY=your-okx-api-key
OKX_SECRET_KEY=your-okx-secret-key

KRAKEN_API_KEY=your-kraken-api-key
KRAKEN_SECRET_KEY=your-kraken-secret-key

COINBASE_API_KEY=your-coinbase-api-key
COINBASE_SECRET_KEY=your-coinbase-secret-key

COINEX_API_KEY=your-coinex-api-key
COINEX_SECRET_KEY=your-coinex-secret-key

# ================ ایمیل ================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@peakfinder.app
SMTP_FROM_NAME=PeakFinder

# ================ تلگرام ================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ================ کیف پول (برای پنل مدیریت) ================
USDT_WALLET_ADDRESS=your-usdt-trc20-address
BTC_WALLET_ADDRESS=your-btc-address
ETH_WALLET_ADDRESS=your-eth-address
BNB_WALLET_ADDRESS=your-bnb-address
TON_WALLET_ADDRESS=your-ton-address

# ================ مانیتورینگ ================
SENTRY_DSN=your-sentry-dsn

# ================ امنیت ================
CORS_ORIGINS=http://localhost:3000,https://peakfinder.app
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ================ اشتراک ================
TRIAL_DAYS=3
SUBSCRIPTION_PRICE=5.0
SUBSCRIPTION_CURRENCY=USDT